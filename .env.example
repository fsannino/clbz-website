# Copiar para .env e preencher. Nunca commitar .env.
# Em produção, as variáveis ficam no painel da Vercel.

# --- Obrigatórias ---
JWT_SECRET=change-me-in-production
DATABASE_URL=mysql://user:pass@host:3306/dbname
OAUTH_SERVER_URL=https://oauth.example.com
VITE_APP_ID=your-app-id
OWNER_OPEN_ID=your-owner-openid
BUILT_IN_FORGE_API_URL=https://forge.example.com
BUILT_IN_FORGE_API_KEY=your-forge-bearer

# --- Opcionais ---
# Analytics (Plausible). Quando vazio, o script não carrega.
VITE_PLAUSIBLE_DOMAIN=
# VITE_PLAUSIBLE_HOST=https://plausible.io

# OAuth portal (opcional se houver login visível no site)
VITE_OAUTH_PORTAL_URL=

# Porta local (opcional)
PORT=3000
